; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Radical Ramapge"
run/main_scene="uid://bbw2scq626wau"
config/features=PackedStringArray("4.5", "C#", "Forward Plus")
boot_splash/bg_color=Color(0, 0.72671556, 0.8490468, 1)
boot_splash/image="uid://bvokxk83ohi37"
config/icon="uid://bvokxk83ohi37"

[autoload]

Global="*res://Code/Global.gd"
SceneTransition="*res://Scenes/UI/SceneTransition.tscn"
MenuMusic="*res://Scenes/UI/menuMusic.tscn"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
mouse_cursor/custom_image="uid://buixpyjv8pvsg"

[dotnet]

project/assembly_name="Spray&Pray"

[file_customization]

folder_colors={
"res://Code/": "green",
"res://Fonts/": "red",
"res://Models/": "red",
"res://Resources/": "blue",
"res://Scenes/": "teal",
"res://Sounds/": "yellow",
"res://Textures/": "pink"
}

